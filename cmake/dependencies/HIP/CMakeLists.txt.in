cmake_minimum_required(VERSION @CMAKE_VERSION@)
project(numeric-hip-install)


include(ExternalProject)


ExternalProject_Add(
  hipcc
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/hipcc-src
  SOURCE_SUBDIR amd/hipcc
  INSTALL_DIR @FETCHCONTENT_BASE_DIR@/hipcc-install
  GIT_REPOSITORY https://github.com/ROCm/llvm-project.git
  GIT_TAG rocm-6.2.4
  USES_TERMINAL_BUILD ON
  CMAKE_ARGS
    -DCMAKE_INSTALL_PREFIX=@FETCHCONTENT_BASE_DIR@/hipcc-install
    -DCMAKE_BUILD_TYPE=@CMAKE_BUILD_TYPE@
)

ExternalProject_Add(
  hip
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/hip-src
  GIT_REPOSITORY https://github.com/ROCm/HIP.git
  GIT_TAG rocm-6.2.4
  CONFIGURE_COMMAND ""
  BUILD_COMMAND ""
  INSTALL_COMMAND ""
)

ExternalProject_Add(
  hipother
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/hipother-src
  GIT_REPOSITORY https://github.com/ROCm/hipother.git
  GIT_TAG rocm-6.2.4
  CONFIGURE_COMMAND ""
  BUILD_COMMAND ""
  INSTALL_COMMAND ""
)

ExternalProject_Add(
  clr
  DEPENDS hipcc hip hipother
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/clr-src
  INSTALL_DIR @FETCHCONTENT_BASE_DIR@/hipother-install
  GIT_REPOSITORY https://github.com/ROCm/clr.git
  GIT_TAG rocm-6.2.4
  USES_TERMINAL_BUILD ON
  CMAKE_ARGS
    -DCMAKE_INSTALL_PREFIX=@FETCHCONTENT_BASE_DIR@/hipother-install
    -DCMAKE_BUILD_TYPE=@CMAKE_BUILD_TYPE@
    -DHIP_COMMON_DIR=@FETCHCONTENT_BASE_DIR@/hip-src
    -DHIPCC_BIN_DIR=@FETCHCONTENT_BASE_DIR@/hipcc-install/bin
    -DHIP_PLATFORM=nvidia
    -DHIP_CATCH_TEST=0
    -DCLR_BUILD_HIP=ON
    -DCLR_BUILD_OCL=OFF
    -DHIPNV_DIR=@FETCHCONTENT_BASE_DIR@/hipother-src/hipnv
)
