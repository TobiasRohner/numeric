cmake_minimum_required(VERSION @CMAKE_VERSION@)
project(numeric-hip-install)


include(ExternalProject)


execute_process(
  COMMAND ./hipconfig --platform
  WORKING_DIRECTORY @HIPCC_BIN_DIR@
  OUTPUT_VARIABLE NUMERIC_HIP_PLATFORM
  COMMAND_ERROR_IS_FATAL ANY
)


ExternalProject_Add(
  hip
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/hip-src
  GIT_REPOSITORY https://github.com/ROCm/HIP.git
  GIT_TAG rocm-6.4.1
  CONFIGURE_COMMAND ""
  BUILD_COMMAND ""
  INSTALL_COMMAND ""
)

if (NOT NUMERIC_HIP_PLATFORM STREQUAL "amd")
  ExternalProject_Add(
    hipother
    SOURCE_DIR @FETCHCONTENT_BASE_DIR@/hipother-src
    GIT_REPOSITORY https://github.com/ROCm/hipother.git
    GIT_TAG rocm-6.4.1
    CONFIGURE_COMMAND ""
    BUILD_COMMAND ""
    INSTALL_COMMAND ""
  )
endif()

ExternalProject_Add(
  clr
  DEPENDS hip hipother
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/clr-src
  INSTALL_DIR @FETCHCONTENT_BASE_DIR@/hip-install
  GIT_REPOSITORY https://github.com/ROCm/clr.git
  GIT_TAG rocm-6.4.1
  USES_TERMINAL_BUILD ON
  CMAKE_ARGS
    -DCMAKE_INSTALL_PREFIX=@FETCHCONTENT_BASE_DIR@/hip-install
    -DCMAKE_BUILD_TYPE=@CMAKE_BUILD_TYPE@
    -DHIP_COMMON_DIR=@FETCHCONTENT_BASE_DIR@/hip-src
    -DHIPCC_BIN_DIR=@HIPCC_BIN_DIR@
    -DHIP_PLATFORM=${NUMERIC_HIP_PLATFORM}
    -DHIP_CATCH_TEST=0
    -DCLR_BUILD_HIP=ON
    -DCLR_BUILD_OCL=OFF
    -DHIPNV_DIR=@FETCHCONTENT_BASE_DIR@/hipother-src/hipnv
)
