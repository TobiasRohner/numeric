cmake_minimum_required(VERSION @CMAKE_VERSION@)
project(numeric-hdf5-install)


include(ExternalProject)


if (CMAKE_BUILD_TYPE STREQUAL "Debug")
  set(NUMERIC_HDF5_BUILD_MODE debug)
else()
  set(NUMERIC_HDF5_BUILD_MODE production)
endif()

set(NUMERIC_HDF5_CONFIGURE_COMMAND ./configure)
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --prefix=@FETCHCONTENT_BASE_DIR@/hdf5-install)
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --enable-build-mode=${NUMERIC_HDF5_BUILD_MODE})
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --enable-hl)
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --disable-tests)
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --disable-tools)
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --disable-shared)
set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --enable-static)
if (@NUMERIC_ENABLE_MPI@)
  set(NUMERIC_HDF5_CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND} --enable-parallel)
endif()

ExternalProject_Add(
  hdf5
  SOURCE_DIR @FETCHCONTENT_BASE_DIR@/hdf5-src
  BINARY_DIR @FETCHCONTENT_BASE_DIR@/hdf5-src
  INSTALL_DIR @FETCHCONTENT_BASE_DIR@/hdf5-install
  GIT_REPOSITORY https://github.com/HDFGroup/hdf5.git
  GIT_TAG hdf5-1_12_3
  USES_TERMINAL_BUILD ON
  CONFIGURE_COMMAND ${NUMERIC_HDF5_CONFIGURE_COMMAND}
  BUILD_COMMAND make
  INSTALL_COMMAND make install
)
