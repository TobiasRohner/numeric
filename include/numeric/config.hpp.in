#ifndef NUMERIC_CONFIG_HPP_
#define NUMERIC_CONFIG_HPP_


namespace numeric {

/*
 * Detect the compiler
 */

#define NUMERIC_CLANG_COMPILER 0
#define NUMERIC_GCC_COMPILER 0
#define NUMERIC_MSC_COMPILER 0
#define NUMERIC_NVCC_COMPILER 0

#if defined(__clang__)
#undef NUMERIC_CLANG_COMPILER
#define NUMERIC_CLANG_COMPILER 1
#elif defined(__GNUC__) || defined(__GNUG__)
#undef NUMERIC_GCC_COMPILER
#define NUMERIC_GCC_COMPILER 1
#elif defined(_MSC_VER)
#undef NUMERIC_MSC_COMPILER
#define NUMERIC_MSC_COMPILER 1
#endif
#if defined(__NVCC__)
#undef NUMERIC_NVCC_COMPILER
#define NUMERIC_NVCC_COMPILER 1
#endif

/*
 * Macros to access pretty function names
 */

#if defined(__GNUC__)
#define NUMERIC_PRETTY_FUNCTION __PRETTY_FUNCTION__
#elif defined(_MSC_VER)
#define NUMERIC_PRETTY_FUNCTION __FUNCSIG__
#else
#define NUMERIC_PRETTY_FUNCTION __func__
#endif

/*
 * CUDA Macros
 */

#if NUMERIC_ENABLE_HIP
#ifndef __host__
#define __host__
#endif
#ifndef __device__
#define __device__
#endif
#define NUMERIC_HOST __host__
#define NUMERIC_DEVICE __device__
#define NUMERIC_HOST_DEVICE __host__ __device__
#else
#define NUMERIC_HOST
#define NUMERIC_DEVICE
#define NUMERIC_HOST_DEVICE
#endif

/*
 * General Config Data
 */

using dim_t = long long;

#ifndef __HIP_DEVICE_COMPILE__
static constexpr char *DATA_DIR = "@DATA_DIR@";
static constexpr char *NUMERIC_INCLUDE_DIR = "@NUMERIC_INCLUDE_DIR@";
static constexpr char *CMAKE_BUILD_TYPE = "@CMAKE_BUILD_TYPE@";
static constexpr char *CMAKE_HIP_FLAGS = "@CMAKE_HIP_FLAGS@";
#endif

}


#endif
